# LLM Provider Configuration

# Default LLM Provider (optional, defaults to OPENAI)
# Determines which {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL, {PROVIDER}_MODEL to use
# Examples: OPENAI, DEEPSEEK, GEMINI, ANTHROPIC
# LLM_PROVIDER=OPENAI

# API Key (required)
OPENAI_API_KEY=your-api-key-here

# Base URL (REQUIRED — startup fails with ValueError if not set)
# For OpenAI: https://api.openai.com/v1
# For other providers: use their base URL
OPENAI_BASE_URL=https://api.openai.com/v1

# Model (REQUIRED — startup fails with ValueError if not set)
# For OpenAI: gpt-5.4, gpt-4.1, etc.
# For Claude via OpenAI-compatible endpoint: claude-sonnet-4-6, claude-opus-4-6, etc.
OPENAI_MODEL=gpt-5.4

# LLM Temperature (0.0-2.0, default: 0.2, lower = more deterministic)
# LLM_TEMPERATURE=0.2

# ─── Web Search ─────────────────────────────────────────────────────────────
# If set, web_search uses Bocha Search API (higher quality structured results).
# Without this key the tool falls back to DuckDuckGo (no account needed).
# Get a key at https://bochaai.com
# BOCHA_API_KEY=your-bocha-key-here
