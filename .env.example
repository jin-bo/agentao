# LLM Provider Configuration

# Default LLM Provider (optional, defaults to OPENAI)
# Determines which {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL, {PROVIDER}_MODEL to use
# Examples: OPENAI, DEEPSEEK, GEMINI, ANTHROPIC
# LLM_PROVIDER=OPENAI

# API Key (required)
OPENAI_API_KEY=your-api-key-here

# Base URL (REQUIRED — startup fails with ValueError if not set)
# For OpenAI: https://api.openai.com/v1
# For other providers: use their base URL
OPENAI_BASE_URL=https://api.openai.com/v1

# Model (REQUIRED — startup fails with ValueError if not set)
# For OpenAI: gpt-5.4, gpt-4.1, etc.
# For Claude via OpenAI-compatible endpoint: claude-sonnet-4-6, claude-opus-4-6, etc.
OPENAI_MODEL=gpt-5.4

# LLM Temperature (0.0-2.0, default: 0.2, lower = more deterministic)
# LLM_TEMPERATURE=0.2

# ─── Web Search ─────────────────────────────────────────────────────────────
# web_search runs an ordered fallback chain, retreating to the next backend
# whenever one errors (an empty "no results" answer is NOT a failure):
#       jina (if JINA_API_KEY)  →  bocha (if BOCHA_API_KEY)  →  duckduckgo
# DuckDuckGo is keyless and always the last resort, so search keeps working with
# no keys at all. Pinning WebSearchTool(backend="...") disables the fallback.
#
# Bocha — higher-quality structured results. Get a key at https://bochaai.com
# BOCHA_API_KEY=your-bocha-key-here
#
# Jina (s.jina.ai) — works without a key (rate-limited); a key only lifts the
# rate limit. Get a key at https://jina.ai
# JINA_API_KEY=your-jina-key-here

# ─── Web Fetch (JS-rendering fallback) ──────────────────────────────────────
# web_fetch uses a direct httpx GET by default. When a page requires JS
# rendering or the direct fetch fails, set this to opt in to a fallback:
#   jina      — sends the URL to https://r.jina.ai (third-party service);
#               disclosed in the tool description and result audit line.
#   crawl4ai  — local headless browser; requires:
#                 pip install 'agentao[crawl4ai]'
#                 playwright install chromium
#   none      — (default) no fallback; on a JS-detected page the tool
#               returns the static shell with a warning Note.
# AGENTAO_WEB_FETCH_FALLBACK=none

# Optional: higher rate limits when AGENTAO_WEB_FETCH_FALLBACK=jina
# JINA_API_KEY=your-jina-key-here

# ─── Web Fetch (SSRF allowlist) ─────────────────────────────────────────────
# web_fetch rejects any URL that resolves to a non-public address (loopback /
# private / link-local / cloud-metadata) — the SSRF guard. If you run behind a
# fake-IP proxy (Clash / V2Ray / Surge map every domain to a reserved range,
# typically 198.18.0.0/15), public sites resolve to those reserved IPs and get
# blocked. Opt specific CIDRs (or bare IPs) back in here — comma/space
# separated. This RELAXES an SSRF control (logged once at startup); keep it as
# narrow as possible and never add 0.0.0.0/0. Default empty = fully strict.
# Cleaner alternative: switch the proxy DNS from fake-ip to redir-host/real-ip.
# AGENTAO_WEB_FETCH_ALLOW_CIDRS=198.18.0.0/15
